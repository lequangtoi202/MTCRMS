NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

DB_HOST=mysql
DB_PORT=3306
DB_PUBLIC_PORT=3307
DB_USERNAME=mtcrms
DB_PASSWORD=mtcrms
DB_NAME=mtcrms
DB_SYNC=true
DB_LOGGING=false

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PUBLIC_PORT=6380

JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_PASSWORD_REQUIRE_UPPERCASE=true
AUTH_PASSWORD_REQUIRE_LOWERCASE=true
AUTH_PASSWORD_REQUIRE_NUMBER=true
AUTH_PASSWORD_REQUIRE_SPECIAL=true

AUTH_BOOTSTRAP_ADMIN_MSSQ=admin001
AUTH_BOOTSTRAP_ADMIN_PASSWORD=Admin@123
AUTH_BOOTSTRAP_ADMIN_FULL_NAME=System Administrator
